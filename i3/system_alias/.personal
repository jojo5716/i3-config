eval $(keychain --eval --agents ssh id_ed25519 making)

#  ==============##############=================
# ================= GIT ========================
#  ==============##############=================

parse_git_branch() {
    git branch 2> /dev/null | sed -e '/^[^*]/d' -e 's/* \(.*\)/ (\1)/'
}
export PS1="\$(get_branch)${PS1}"
export PS1='\u@\h \[\033[32m\]\w\[\033[33m\]$(parse_git_branch)$ '

#  ==============##############=================
#  ============== Python Virtualenv =================
#  ==============##############=================
export VIRTUALENVWRAPPER_PYTHON=/usr/bin/python3
export WORKON_HOME=$HOME/.virtualenvs
export PROJECT_HOME=$HOME/
source /usr/share/virtualenvwrapper/virtualenvwrapper.sh

pyclean () {
    find . -regex '^.*\(__pycache__\|\.py[co]\)$' -delete
}

#  ==============##############=================
# ============== Python poetry ================
#  ==============##############=================
export PATH="/home/jojo/.local/bin:$PATH"

#  ==============##############=================
#  ============== Python PyEnv =================
#  ==============##############=================
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init - bash)"
export PATH="$PYENV_ROOT/bin:$PATH"

#  ==============##############=================
#  ============== Docker alias =================
#  ==============##############=================
alias docker_stop="docker stop \$(docker ps -a -q)"
alias docker_rm="docker rm \$(docker ps -a -q)"
docker_nuke() {
  # Parar y borrar TODOS los contenedores
  docker ps -aq | xargs -r docker stop
  docker ps -aq | xargs -r docker rm -f

  # Borrar TODAS las imágenes
  docker images -aq | xargs -r docker rmi -f

  # Borrar TODOS los volúmenes
  docker volume ls -q | xargs -r docker volume rm -f

  # borrar redes no-default
  docker network ls --format '{{.Name}}' \
    | grep -vE '^(bridge|host|none)$' \
    | xargs -r docker network rm

  # Limpiezas adicionales (por si queda caché/buildkit, etc.)
  docker system prune -af --volumes
  docker builder prune -af
}

alias docker_kill='docker_nuke'

